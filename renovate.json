{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm"
      ],
      "matchDepTypes": [
        "dependencies",
        "devDependencies",
        "optionalDependencies"
      ],
      "rangeStrategy": "pin",
      "minimumReleaseAge": "3 days",
      "automerge": true
    },
    {
      "description": "Angular-Ökosystem als eine PR aktualisieren, um Versionsdrift zu vermeiden",
      "groupName": "Angular ecosystem",
      "groupSlug": "angular-ecosystem",
      "matchManagers": [
        "npm"
      ],
      "rangeStrategy": "replace",
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "automerge": false,
      "matchPackageNames": [
        "/^@angular\\//",
        "/^@angular-eslint\\//",
        "angular-eslint",
        "jest-preset-angular"
      ]
    },
    {
      "description": "Kein Upgrade auf eslint 10+ anbieten",
      "matchPackageNames": [
        "eslint"
      ],
      "allowedVersions": "<10"
    }
  ]
}
