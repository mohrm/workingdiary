{
  "name": "workingdiary",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/update-version.cjs",
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "preview": "node scripts/preview.mjs",
    "prebuild": "node scripts/update-version.cjs",
    "pretest": "node scripts/update-version.cjs",
    "test": "sh scripts/run-tests.sh $(find src -name '*.spec.ts')",
    "test:watch": "node --import tsx --import ./test-setup.ts --experimental-test-coverage --watch --test $(find src -name '*.spec.ts')",
    "test:docker": "bash scripts/test-docker.sh",
    "lint": "biome check",
    "format": "biome check --write",
    "e2e": "npx bddgen -c e2e/playwright.config.js && npx playwright test -c e2e/playwright.config.js",
    "e2e-prepare:ci": "npx playwright install --with-deps && npx bddgen -c e2e/playwright.config.js",
    "e2e:ci": "npx playwright test -c e2e/playwright.config.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "esbuild": "0.28.1",
    "playwright-bdd": "9.2.0",
    "sass-embedded": "1.100.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
