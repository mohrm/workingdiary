{
  "name": "workingdiary",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "npx bddgen -c e2e/playwright.config.js && npx playwright test -c e2e/playwright.config.js",
    "prebuild": "node scripts/update-version.js",
    "build:ci": "ng build --configuration production",
    "e2e-prepare:ci": "npx playwright install --with-deps && npx bddgen -c e2e/playwright.config.js",
    "e2e:ci": "npx playwright test -c e2e/playwright.config.js",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.6",
    "@angular/cdk": "22.0.4",
    "@angular/common": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/material": "22.0.4",
    "@angular/platform-browser": "22.0.6",
    "@angular/platform-browser-dynamic": "22.0.6",
    "@angular/router": "22.0.6",
    "@angular/service-worker": "22.0.6",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "@angular/compiler": "22.0.6"
  },
  "devDependencies": {
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@playwright/test": "1.61.1",
    "@types/jest": "30.0.0",
    "angular-eslint": "22.0.0",
    "eslint": "9.39.5",
    "istanbul-lib-instrument": "6.0.3",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-preset-angular": "17.0.0",
    "playwright-bdd": "9.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
