{
  "name": "workingdiary",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prebuild": "node scripts/update-version.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e": "npx bddgen -c e2e/playwright.config.js && npx playwright test -c e2e/playwright.config.js",
    "e2e-prepare:ci": "npx playwright install --with-deps && npx bddgen -c e2e/playwright.config.js",
    "e2e:ci": "npx playwright test -c e2e/playwright.config.js"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0",
    "@types/jest": "30.0.0",
    "@types/node": "^22.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "playwright-bdd": "9.2.0",
    "sass-embedded": "^1.100.0",
    "ts-jest": "^29.4.11",
    "typescript": "6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
